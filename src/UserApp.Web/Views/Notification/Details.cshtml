@model UserApp.Web.ViewModels.NotificationViewModel

<div class="max-w-2xl mx-auto animate-fade-in">
    <div class="mb-8">
        <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Notifications
        </a>
        <h1 class="text-3xl font-black text-slate-800 tracking-tight mt-2">Notification Details</h1>
        <p class="text-slate-500 text-sm mt-1">View Notification record details</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <div class="space-y-6">
            <div>
                <label class="block text-sm font-bold text-slate-500 mb-1">Name</label>
                <p class="text-slate-800 font-semibold">@Model.Name</p>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-500 mb-1">Type</label>
                <p class="text-slate-800 font-semibold">@Model.Type</p>
            </div>

            @if (Model.MediaList.Count > 0)
            {
                <div>
                    <label class="block text-sm font-bold text-slate-500 mb-3">Images</label>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                        @foreach (var media in Model.MediaList)
                        {
                            <div class="bg-slate-50 rounded-xl border border-slate-200 p-2">
                                <div class="relative aspect-square rounded-lg overflow-hidden bg-slate-100">
                                    <img src="@media.Url" alt="@media.OriginalName"
                                         class="w-full h-full object-cover" />
                                </div>
                                <p class="mt-2 text-xs text-slate-500 truncate px-1">@media.OriginalName</p>
                            </div>
                        }
                    </div>
                </div>
            }
        
                                                        @if (ViewData["ChildData"] is List<Dictionary<string, object>> childSections && childSections.Count > 0)
            {
                <div class="pt-6 border-t border-slate-100">
                    <button onclick="toggleChildData()"
                            class="w-full px-6 py-3 text-sm font-bold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 rounded-xl transition-colors flex items-center justify-center gap-2">
                        <svg class="w-4 h-4 transition-transform child-data-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                        <span class="child-data-text">View Related Data</span>
                    </button>
                </div>

                <div class="child-data-container" style="display: none;">
                    @foreach (var section in childSections)
                    {
                        var entityName = section["EntityName"]?.ToString() ?? "";
                        var controllerName = section["ControllerName"]?.ToString() ?? "";
                        var records = section["Records"] as List<Dictionary<string, string>> ?? new();
                        if (records.Count == 0) continue;
                        var headers = records[0].Keys.ToList();
                        if (headers.Count == 0) continue;

                        <div class="pt-6 border-t border-slate-100">
                            <h2 class="text-lg font-bold text-slate-700 mb-4">@entityName</h2>
                            <div class="overflow-x-auto rounded-xl border border-slate-200">
                                <table class="min-w-full divide-y divide-slate-200">
                                    <thead class="bg-slate-50">
                                        <tr>
                                            @foreach (var header in headers.Where(h => h != "Id"))
                                            {
                                                <th class="px-4 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">@header</th>
                                            }
                                            <th class="px-4 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-slate-200">
                                        @foreach (var record in records)
                                        {
                                            <tr>
                                                @foreach (var kvp in record.Where(k => k.Key != "Id"))
                                                {
                                                    <td class="px-4 py-3 text-sm text-slate-700">
                                                        @if (kvp.Key == "Image" && !string.IsNullOrEmpty(kvp.Value))
                                                        {
                                                            <img src="@kvp.Value" class="w-16 h-16 object-cover rounded-lg border border-slate-200" />
                                                        }
                                                        else
                                                        {
                                                            @kvp.Value
                                                        }
                                                    </td>
                                                }
                                                <td class="px-4 py-3 text-sm">
                                                    <a href="/@controllerName/Details/@record["Id"]"
                                                       class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 font-medium">
                                                        View
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
</div>

        <div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-100">
            <a asp-action="Index"
               class="px-6 py-2.5 text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">
                Back to List
            </a>
        </div>
    </div>
</div>


<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

        <script>
            function toggleChildData() {
                var container = document.querySelector('.child-data-container');
                var text = document.querySelector('.child-data-text');
                var chevron = document.querySelector('.child-data-chevron');
                if (!container) return;
                var isHidden = container.style.display === 'none';
                container.style.display = isHidden ? 'block' : 'none';
                if (text) text.innerText = isHidden ? 'Hide Related Data' : 'View Related Data';
                if (chevron) chevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
            }
        </script>

