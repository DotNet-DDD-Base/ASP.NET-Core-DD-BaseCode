@model ProductViewModel
@using UserApp.Web.ViewModels.Products

<div class="max-w-2xl mx-auto animate-fade-in">
    <div class="mb-8">
        <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Products
        </a>
        <h1 class="text-3xl font-black text-slate-800 tracking-tight mt-2">New Product</h1>
        <p class="text-slate-500 text-sm mt-1">Create a new product with status</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-rose-600 mb-6 text-sm font-medium"></div>

            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-bold text-slate-700 mb-1.5">Name</label>
                    <input asp-for="Name"
                           class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200" />
                    <span asp-validation-for="Name" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Status" class="block text-sm font-bold text-slate-700 mb-1.5">Status</label>
                    <select asp-for="Status" asp-items="Model.StatusOptions"
                            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 font-medium focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200">
                        <option value="">-- Select Status --</option>
                    </select>
                    <span asp-validation-for="Status" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Paymet" class="block text-sm font-bold text-slate-700 mb-1.5">Payment</label>
                    <select asp-for="Paymet" asp-items="Model.PaymetOptions"
                            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 font-medium focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200">
                        <option value="">-- Select Payment --</option>
                    </select>
                    <span asp-validation-for="Paymet" class="text-xs text-rose-500 mt-1"></span>
                </div>
            </div>

            <div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-100">
                <button type="submit"
                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl shadow-lg shadow-indigo-200 hover:shadow-indigo-300 transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0">
                    Create Product
                </button>
                <a asp-action="Index"
                   class="px-6 py-2.5 text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .input-validation-error {
        border-color: #f43f5e !important;
        background-color: #fff1f2 !important;
    }
    .field-validation-error {
        color: #f43f5e;
        font-size: 0.75rem;
        margin-top: 0.25rem;
        display: block;
    }
    .validation-summary-errors {
        color: #f43f5e;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }
    .validation-summary-errors ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .validation-summary-errors li {
        padding: 0.25rem 0;
    }
</style>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
