<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
<nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
    <div class="container">
        <a class="navbar-brand" asp-controller="Users" asp-action="Index">UserApp</a>
        <div>
            <a class="nav-link text-light d-inline" asp-controller="Users" asp-action="Index">Users</a>
        </div>
        <a class="navbar-brand" asp-controller="Products" asp-action="Index">ProductApp</a>
        <div>
            <a class="nav-link text-light d-inline" asp-controller="Products" asp-action="Index">Producs</a>
        </div>
    </div>
</nav>
<main class="container">
    @RenderBody()
    @RenderSection("Scripts", required: false)
</main>
</body>
</html>
