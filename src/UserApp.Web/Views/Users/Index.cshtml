@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between mb-3">
    <h2>Users</h2>
    <a class="btn btn-success" asp-action="Create">+ New User</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Full Name</th>
            <th>Status</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var u in Model.Items)
        {
            <tr>
                <td>@u.Email</td>
                <td>@u.FullName</td>
                <td>@u.Status</td>
                <td>@u.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@u.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
            </li>
        }
    </ul>
</nav>