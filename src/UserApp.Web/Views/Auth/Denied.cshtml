@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] &mdash; UserApp</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    
    <style>
        body {
            font-family: 'Lato', sans-serif;
            background-color: #fafafa;
            /* Visual Depth: Architectural blueprint grid style */
            background-image: 
                linear-gradient(to right, rgba(0, 0, 0, 0.03) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
            background-size: 32px 32px;
            background-position: center;
        }

        /* Easing profiles for complex object animations */
        .reveal-card {
            animation: revealCard 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @@keyframes revealCard {
            from {
                opacity: 0;
                transform: translateY(24px) scale(0.98);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
    </style>
</head>
<body class="h-full flex flex-col items-center justify-center antialiased selection:bg-neutral-900 selection:text-white p-8 sm:p-12">

    <main class="w-full max-w-md reveal-card">
        
        <div class="bg-white border-2 border-neutral-900 rounded-3xl p-10 md:p-12 shadow-[8px_8px_0px_rgba(0,0,0,1)] text-center relative overflow-hidden">
            
            <div class="w-24 h-24 mx-auto mb-8 flex items-center justify-center bg-neutral-50 rounded-2xl border-2 border-neutral-900 shadow-[4px_4px_0px_rgba(0,0,0,1)]">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-neutral-900">
                    <path d="M20 13c0 5-3.5 7.5-7.66 9.7a1 1 0 0 1-.68 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 .76-.97l7-2a1 1 0 0 1 .48 0l7 2A1 1 0 0 1 20 6z"/>
                    <circle cx="12" cy="11" r="1.5" fill="currentColor"/>
                    <path d="M12 12.5V15" />
                </svg>
            </div>

            <h1 class="text-2xl font-black text-neutral-900 tracking-tight mb-2 uppercase">
                403 Restrictive Halt
            </h1>
            
            <div class="inline-block px-2.5 py-1 text-[10px] font-mono font-bold bg-neutral-100 text-neutral-800 rounded-md uppercase tracking-wider mb-6 border border-neutral-200">
                Scope: Access_Token_Missing
            </div>
            
            <p class="text-sm text-neutral-600 font-normal leading-relaxed max-w-sm mx-auto mb-10">
                Your authenticated environment profile lacks the specific authorization flags or functional access privileges required to parse this workspace endpoint module.
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
                <a href="javascript:history.back()" class="flex-1 flex items-center justify-center px-4 py-3 bg-white hover:bg-neutral-50 active:bg-neutral-100 text-neutral-900 font-bold text-sm rounded-xl border-2 border-neutral-900 transition-all duration-150 ease-out active:translate-y-[1px]">
                    Go Back
                </a>
                <a href="/Auth/Login" class="flex-1 flex items-center justify-center px-4 py-3 bg-neutral-900 hover:bg-neutral-800 active:bg-neutral-950 text-white font-bold text-sm rounded-xl border-2 border-neutral-900 shadow-[1px_1px_0px_rgba(0,0,0,0.15)] transition-all duration-150 ease-out active:translate-y-[1px]">
                    Re-Authenticate
                </a>
            </div>

        </div>

        <div class="mt-6 text-center text-[11px] font-mono text-neutral-400 uppercase tracking-widest">
            System Security Shield Verification Active
        </div>

    </main>

</body>
</html>