@model UserApp.Web.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - UserApp</title>
    
    <!-- Premium Google Fonts: Lato -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: 'Lato', sans-serif;
            background-color: #f8fafc; /* Crisp, ultra-clean off-white background */
            background-image: radial-gradient(circle at 50% 50%, #ffffff 0%, #f1f5f9 100%);
            overflow-x: hidden;
        }

        /* Subtle luxury ambient texture */
        .ambient-light {
            background: radial-gradient(circle, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0) 70%);
        }

        /* Smooth scale-up & fade transition on load */
        .login-card {
            opacity: 0;
            transform: translateY(16px) scale(0.98);
            animation: cardAppear 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.05), 
                        0 0 0 1px rgba(0, 0, 0, 0.04);
        }

        @@keyframes cardAppear {
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* Floating label mechanics (Black focus text) */
        .input-group input:focus ~ label,
        .input-group input:not(:placeholder-shown) ~ label {
            transform: translateY(-1.15rem) scale(0.8);
            color: #000000; /* Crisp Black focus color */
        }

        /* Smooth border-glow micro-interaction */
        .glow-focus {
            transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .glow-focus:focus-within {
            border-color: #000000;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="relative flex min-h-screen w-full items-center justify-center p-4 antialiased">

    <!-- Ambient Subtle Background Depth -->
    <div class="ambient-light absolute top-0 left-0 h-full w-full pointer-events-none"></div>

    <!-- Login Container -->
    <div class="login-card z-10 w-full max-w-[440px] rounded-2xl bg-white p-8 md:p-10">
        
        <!-- Brand/Logo Header -->
        <div class="mb-8 text-center">
            <!-- Minimalist Black & White Logo Mark -->
            <div class="mx-auto mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-black shadow-md shadow-black/5">
                <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.519 1.116-3.113 1.382-4.79" />
                </svg>
            </div>
            <a herf="/Auth/" class="text-2xl font-bold tracking-tight text-slate-950 md:text-3xl">Sign in to your account</a>
            <p class="mt-2.5 text-sm text-slate-500">Please enter your credentials below</p>
        </div>

        <!-- Validation Summary Container (Styled to fit the clean layout) -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800 animate-pulse">
                <svg class="h-5 w-5 shrink-0 text-red-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <div asp-validation-summary="All" class="list-none leading-relaxed font-medium"></div>
            </div>
        }

        <!-- Interactive Form -->
        <form method="post" id="loginForm" class="space-y-5">
            
            <!-- Email Input Group -->
            <div class="input-group glow-focus relative rounded-xl border border-slate-200 bg-slate-50/50 transition-all duration-300">
                <div class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 transition-colors duration-200">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
                    </svg>
                </div>
                <input asp-for="Email" 
                       type="email"
                       placeholder=" " 
                       autocomplete="email"
                       class="w-full bg-transparent pl-12 pr-4 py-4 text-sm text-slate-900 placeholder-transparent outline-none transition-all" />
                <label asp-for="Email" 
                       class="pointer-events-none absolute left-12 top-4 origin-left text-sm text-slate-400 transition-all duration-300 ease-out">
                    Email address
                </label>
            </div>
            <span asp-validation-for="Email" class="mt-1 block text-xs text-red-600 px-1 font-medium"></span>

            <!-- Password Input Group -->
            <div class="input-group glow-focus relative rounded-xl border border-slate-200 bg-slate-50/50 transition-all duration-300">
                <div class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <input asp-for="Password" 
                       id="passwordField"
                       type="password" 
                       placeholder=" " 
                       autocomplete="current-password"
                       class="w-full bg-transparent pl-12 pr-12 py-4 text-sm text-slate-900 placeholder-transparent outline-none transition-all" />
                <label asp-for="Password" 
                       class="pointer-events-none absolute left-12 top-4 origin-left text-sm text-slate-400 transition-all duration-300 ease-out">
                    Password
                </label>
                <!-- Show/Hide Password Toggle Button -->
                <button type="button" onclick="togglePasswordVisibility()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-800 focus:outline-none transition-colors">
                    <svg id="eyeIconOpen" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    <svg id="eyeIconClosed" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                    </svg>
                </button>
            </div>
            <span asp-validation-for="Password" class="mt-1 block text-xs text-red-600 px-1 font-medium"></span>

            <!-- Options: Remember me & Forgot Password -->
            <div class="flex items-center justify-between text-sm py-1">
                <label class="group flex cursor-pointer items-center text-slate-500 select-none">
                    <input type="checkbox" class="peer h-4 w-4 rounded border-slate-300 bg-white text-black focus:ring-0 focus:ring-offset-0 transition duration-150 checked:bg-black checked:border-black" />
                    <span class="ml-2.5 transition-colors group-hover:text-slate-800">Remember me</span>
                </label>
                <a href="@Url.Action("ForgotPassword")" class="font-semibold text-slate-900 hover:text-black hover:underline underline-offset-4 transition-colors duration-150">Forgot password?</a>
            </div>

            <!-- Submit Button (Sleek Matte Black) -->
            <button type="submit" 
                    id="submitBtn"
                    class="group relative flex w-full transform items-center justify-center overflow-hidden rounded-xl bg-black py-4 text-sm font-semibold text-white transition-all duration-300 ease-out hover:bg-slate-900 hover:shadow-lg hover:shadow-black/5 active:scale-[0.985]">
                <span id="btnText" class="transition-all duration-200">Sign In</span>
                
                <!-- Silent Spinner Indicator -->
                <svg id="btnSpinner" class="absolute h-5 w-5 animate-spin text-white opacity-0 transition-opacity duration-200" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </form>

        <!-- Social login divider -->
        <div class="relative my-7 flex items-center justify-center">
            <div class="absolute inset-0 flex items-center" aria-hidden="true">
                <div class="w-full border-t border-slate-100"></div>
            </div>
            <!-- whitespace-nowrap forces 'or continue with' to stay strictly side-by-side -->
            <span class="relative bg-white px-4 text-xs font-semibold uppercase tracking-wider text-slate-400 whitespace-nowrap select-none">or continue with</span>
        </div>

        <!-- Social Logins -->
        <div class="grid grid-cols-2 gap-4">
            <button type="button" class="flex items-center justify-center gap-2.5 rounded-xl border border-slate-200 bg-white py-3.5 text-sm font-medium text-slate-700 transition-all duration-200 hover:bg-slate-50 hover:text-black hover:border-slate-300 active:scale-[0.97]">
                <!-- Google Icon SVG -->
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span>Google</span>
            </button>
            <button type="button" class="flex items-center justify-center gap-2.5 rounded-xl border border-slate-200 bg-white py-3.5 text-sm font-medium text-slate-700 transition-all duration-200 hover:bg-slate-50 hover:text-black hover:border-slate-300 active:scale-[0.97]">
                <!-- Github Icon SVG -->
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.193 22 16.436 22 12.017 22 6.484 17.522 2 12 2z"/>
                </svg>
                <span>GitHub</span>
            </button>
        </div>

        <!-- Footer Actions -->
        <div class="mt-8 text-center text-sm text-slate-500">
            Don't have an account? 
<a asp-action="Register"
   class="font-bold text-slate-900 hover:text-black hover:underline underline-offset-4 transition-colors duration-150">
    Sign up
</a>        </div>
    </div>

    <!-- Scripts for dynamic interactions and state transition feedbacks -->
    <script>
        function togglePasswordVisibility() {
            const passwordField = document.getElementById("passwordField");
            const eyeOpen = document.getElementById("eyeIconOpen");
            const eyeClosed = document.getElementById("eyeIconClosed");

            if (passwordField.type === "password") {
                passwordField.type = "text";
                eyeOpen.classList.remove("hidden");
                eyeClosed.classList.add("hidden");
            } else {
                passwordField.type = "password";
                eyeOpen.classList.add("hidden");
                eyeClosed.classList.remove("hidden");
            }
        }

        // Show immediate loading animation on post submit
        const loginForm = document.getElementById("loginForm");
        loginForm.addEventListener("submit", function () {
            const btn = document.getElementById("submitBtn");
            const btnText = document.getElementById("btnText");
            const btnSpinner = document.getElementById("btnSpinner");

            btn.disabled = true;
            btnText.classList.add("opacity-0");
            btnSpinner.classList.remove("opacity-0");
        });
    </script>
</body>
</html>