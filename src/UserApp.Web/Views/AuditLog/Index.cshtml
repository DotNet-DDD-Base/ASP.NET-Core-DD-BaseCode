@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.AuditLogs.AuditLogViewModel>
@{
    var today = DateTime.Now.ToString("yyyy-MM-dd");
    var modelFromDate = Model.FromDate?.ToString("yyyy-MM-dd");
    var modelToDate = Model.ToDate?.ToString("yyyy-MM-dd");
    var isArchived = Model.FromDate.HasValue && Model.FromDate.Value.Date < DateTime.Now.Date;
}

<div class="animate-fade-in">
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-baseline gap-3">
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Audit Logs</h1>
            <p class="text-slate-500 text-sm">Track all changes made across the system</p>
        </div>
        <div class="flex items-center gap-2">
            @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
            {
                <form asp-action="TestArchive" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="px-4 py-2.5 rounded-xl bg-amber-50 text-amber-700 border border-amber-200 hover:bg-amber-100 text-sm font-medium transition-all duration-200 whitespace-nowrap">
                        Test Archive
                    </button>
                </form>
            }
            <button id="resetBtn" type="button"
                    class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-500 hover:text-slate-700 hover:bg-slate-100 text-sm font-medium transition-all duration-200 @(string.IsNullOrEmpty(modelFromDate) && string.IsNullOrEmpty(modelToDate) ? "hidden" : "")">
                <svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Reset
            </button>
            <div class="relative w-72">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="text" id="searchInput" value="@Model.SearchTerm"
                       placeholder="Search by user, action, entity..."
                       class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200 text-sm" />
            </div>
        </div>
    </div>

    <div class="flex items-center gap-3 mb-6">
        <span class="text-sm font-semibold text-slate-500 whitespace-nowrap">Date Range</span>
        <div class="flex items-center gap-2">
            <input type="date" id="fromDate" value="@modelFromDate" max="@today"
                   class="px-3 py-2 rounded-lg border border-slate-200 bg-white text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200 text-sm" />
            <span class="text-slate-400">—</span>
            <input type="date" id="toDate" value="@modelToDate" max="@today"
                   class="px-3 py-2 rounded-lg border border-slate-200 bg-white text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200 text-sm" />
        </div>
        @if (isArchived)
        {
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-indigo-50 text-indigo-600 border border-indigo-100">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                </svg>
                Archived — @Model.FromDate?.ToString("MMM dd, yyyy")
            </span>
        }
    </div>

    <div id="tableContainer" class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <partial name="_AuditLogTable" model="Model" />
    </div>

    <div id="paginationContainer" class="mt-6">
        <partial name="_AuditLogPagination" model="Model" />
    </div>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .fade-out {
        opacity: 0;
        transform: translateY(-8px);
        transition: all 0.2s ease;
    }
    .fade-in {
        opacity: 1;
        transform: translateY(0);
        transition: all 0.25s ease;
    }
</style>

<script>
    let searchTimer;
    const searchInput = document.getElementById('searchInput');
    const fromDate = document.getElementById('fromDate');
    const toDate = document.getElementById('toDate');
    const resetBtn = document.getElementById('resetBtn');
    const tableContainer = document.getElementById('tableContainer');
    const paginationContainer = document.getElementById('paginationContainer');

    function loadTable(search, page) {
        const params = new URLSearchParams();
        if (search) params.set('search', search);
        params.set('page', page);
        params.set('size', '10');
        if (fromDate.value) params.set('fromDate', fromDate.value);
        if (toDate.value) params.set('toDate', toDate.value);

        tableContainer.style.opacity = '0.5';
        tableContainer.style.transform = 'translateY(-4px)';
        tableContainer.style.transition = 'all 0.15s ease';

        fetch('@Url.Action("SearchData", "AuditLog")?' + params.toString())
            .then(r => r.json())
            .then(data => {
                tableContainer.innerHTML = data.tableHtml;
                paginationContainer.innerHTML = data.paginationHtml;
                tableContainer.style.opacity = '1';
                tableContainer.style.transform = 'translateY(0)';
                tableContainer.style.transition = 'all 0.25s ease';
                attachPageLinks();
            });
    }

    function attachPageLinks() {
        document.querySelectorAll('.page-link').forEach(function(el) {
            el.addEventListener('click', function(e) {
                e.preventDefault();
                const page = this.getAttribute('data-page');
                loadTable(searchInput.value.trim(), page);
            });
        });
    }

    searchInput.addEventListener('input', function() {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => {
            loadTable(this.value.trim(), 1);
        }, 300);
    });

    fromDate.addEventListener('change', function() {
        toDate.min = this.value;
        if (toDate.value && toDate.value < this.value) {
            toDate.value = this.value;
        }
        resetBtn.classList.remove('hidden');
        loadTable(searchInput.value.trim(), 1);
    });

    toDate.addEventListener('change', function() {
        resetBtn.classList.remove('hidden');
        loadTable(searchInput.value.trim(), 1);
    });

    resetBtn.addEventListener('click', function() {
        fromDate.value = '';
        toDate.value = '';
        toDate.min = '';
        this.classList.add('hidden');
        loadTable(searchInput.value.trim(), 1);
    });

    toDate.min = fromDate.value;
    attachPageLinks();
</script>